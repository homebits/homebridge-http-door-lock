{
  "pluginAlias": "HttpLock",
  "pluginType": "platform",
  "singular": false,
  "schema": {
    "type": "object",
    "properties": {
      "locks": {
        "title": "Locks",
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "name": {
              "type": "string"
            },
            "manufacturer": {
              "type": "string"
            },
            "model": {
              "type": "string"
            },
            "serial": {
              "type": "string"
            },
            "firmware": {
              "type": "string"
            },
            "openEndpoint": {
              "type": "string",
              "items": {
                "type": "object",
                "properties": {
                  "url": {
                    "type": "string"
                  },
                  "method": {
                    "type": "string"
                  },
                  "headers": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "name": {
                          "type": "string"
                        },
                        "value": {
                          "type": "string"
                        }
                      },
                      "required": []
                    }
                  }
                },
                "required": [
                  "url"
                ]
              }
            },
            "closeEndpoint": {
              "type": "string",
              "items": {
                "type": "object",
                "properties": {
                  "url": {
                    "type": "string"
                  },
                  "method": {
                    "type": "string"
                  },
                  "headers": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "name": {
                          "type": "string"
                        },
                        "value": {
                          "type": "string"
                        }
                      },
                      "required": []
                    }
                  }
                },
                "required": [
                  "url"
                ]
              }
            },
            "autoLock": {
              "type": "object",
              "properties": {
                "enabled": {
                  "type": "boolean",
                  "default": false
                },
                "delay": {
                  "type": "number",
                  "default": 5,
                  "minimum": 1
                }
              }
            },
            "resetLock": {
              "type": "object",
              "properties": {
                "enabled": {
                  "type": "boolean",
                  "default": false
                },
                "delay": {
                  "type": "number",
                  "default": 5,
                  "minimum": 1
                }
              }
            },
            "required": [
              "name",
              "openEndpoint"
            ]
          }
        }
      }
    }
  }
}